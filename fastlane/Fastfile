default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  private_lane :connect_api_token do
    Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: ENV.fetch("ASC_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  # CI에서는 모든 인증서를 정리해 한도·포털/키체인 불일치를 해소합니다.
  private_lane :prune_certificates do
    Spaceship::ConnectAPI.token = connect_api_token

    certificates = Spaceship::ConnectAPI::Certificate.all
    UI.message("Found #{certificates.length} certificates on developer account")

    if ENV["CI"]
      certificates.each do |certificate|
        UI.message("Revoking CI certificate [#{certificate.certificate_type}]: #{certificate.display_name} (#{certificate.id})")
        certificate.delete!
      end
    else
      certificates.each do |certificate|
        next unless certificate.expiration_date

        expires_at = Time.parse(certificate.expiration_date.to_s)
        next if expires_at >= Time.now

        UI.message("Revoking expired certificate: #{certificate.display_name} (#{certificate.id})")
        certificate.delete!
      end
    end
  end

  private_lane :ci_keychain_path do
    File.expand_path("#{lane_context[SharedValues::KEYCHAIN_PATH]}-db")
  end

  private_lane :install_wwdr_certificate do
    keychain_path = ci_keychain_path
    wwdr_urls = [
      "https://www.apple.com/certificateauthority/AppleWWDRCAG4.cer",
      "https://www.apple.com/certificateauthority/AppleWWDRCAG3.cer",
      "https://www.apple.com/appleca/AppleIncRootCertificate.cer"
    ]

    wwdr_urls.each_with_index do |url, index|
      path = "/tmp/wwdr_#{index}.cer"
      sh("curl -sfL #{url} -o #{path}")
      sh("security import #{path} -k #{keychain_path} -T /usr/bin/codesign -T /usr/bin/security -A")
    end
  end

  private_lane :setup_distribution_signing do |options|
    api_key = options[:api_key]

    prune_certificates
    install_wwdr_certificate

    cert(
      api_key: api_key,
      force: false,
      keychain_path: ci_keychain_path,
      keychain_password: ""
    )

    sigh(
      api_key: api_key,
      app_identifier: "com.ijaejun.anyapp",
      force: true
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "anyapp.xcodeproj",
      targets: ["anyapp"],
      team_id: "T5CBR768BM",
      bundle_identifier: "com.ijaejun.anyapp",
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution"
    )

    profile_name
  end

  private_lane :configure_signing do |options|
    api_key = options[:api_key]

    if ENV["PROVISIONING_PROFILE_NAME"]
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "anyapp.xcodeproj",
        targets: ["anyapp"],
        team_id: "T5CBR768BM",
        bundle_identifier: "com.ijaejun.anyapp",
        profile_name: ENV.fetch("PROVISIONING_PROFILE_NAME"),
        code_sign_identity: "Apple Distribution"
      )
      next ENV.fetch("PROVISIONING_PROFILE_NAME")
    end

    if ENV["CI"]
      next setup_distribution_signing(api_key: api_key)
    end

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "anyapp.xcodeproj",
      targets: ["anyapp"],
      team_id: "T5CBR768BM",
      bundle_identifier: "com.ijaejun.anyapp"
    )

    nil
  end

  # 빌드 번호 = max(GITHUB_RUN_NUMBER, TestFlight 최신 빌드 + 1)
  # 자세한 정책은 docs/release.md 참고
  private_lane :next_build_number do |options|
    api_key = options[:api_key]
    run_number = ENV.fetch("GITHUB_RUN_NUMBER", "0").to_i
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.ijaejun.anyapp",
      initial_build_number: 0
    )
    [run_number, latest + 1].max
  end

  private_lane :recent_testflight_builds do
    Spaceship::ConnectAPI.token = connect_api_token

    app = Spaceship::ConnectAPI::App.find("com.ijaejun.anyapp")
    next [] unless app

    Spaceship::ConnectAPI::Build.all(
      app_id: app.id,
      sort: "-uploadedDate",
      limit: 30
    )
  end

  private_lane :build_uploaded_at do |build|
    raw = build.uploaded_date || build.uploadedDate
    next nil unless raw

    Time.parse(raw.to_s)
  end

  # Apple 일일 업로드 한도(90382)를 피하기 위해 CI에서 업로드 간격·횟수를 제한합니다.
  private_lane :testflight_upload_skip_reason do
    next nil if ENV["FORCE_TESTFLIGHT_UPLOAD"] == "true"
    next nil unless ENV["CI"]

    builds = recent_testflight_builds
    next nil if builds.empty?

    now = Time.now
    cutoff_24h = now - (24 * 3600)
    uploads_last_24h = builds.count do |build|
      uploaded_at = build_uploaded_at(build)
      uploaded_at && uploaded_at > cutoff_24h
    end

    max_per_day = ENV.fetch("TESTFLIGHT_MAX_UPLOADS_PER_24H", "8").to_i
    if uploads_last_24h >= max_per_day
      next "already uploaded #{uploads_last_24h} builds in the last 24 hours (limit: #{max_per_day})"
    end

    latest_upload = builds.lazy.filter_map { |build| build_uploaded_at(build) }.first
    next nil unless latest_upload

    min_interval = ENV.fetch("TESTFLIGHT_MIN_UPLOAD_INTERVAL_MINUTES", "20").to_i
    minutes_since = (now - latest_upload) / 60.0
    if minutes_since < min_interval
      next "last upload was #{minutes_since.round} minutes ago (minimum interval: #{min_interval} minutes)"
    end

    nil
  end

  private_lane :upload_to_testflight_safely do |options|
    upload_to_testflight(
      api_key: options[:api_key],
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      uses_non_exempt_encryption: false
    )
  rescue => error
    message = error.message.to_s
    if message.include?("90382") || message.include?("Upload limit reached")
      UI.important(
        "TestFlight upload skipped: Apple daily upload limit reached (90382). " \
        "Re-run the workflow with force_upload after the limit resets."
      )
      next
    end

    raise error
  end

  desc "Build and upload a beta build to TestFlight"
  lane :beta do
    api_key = asc_api_key

    if (skip_reason = testflight_upload_skip_reason)
      UI.important("TestFlight deploy skipped before build: #{skip_reason}")
      UI.success("CI completed without build or upload.")
      next
    end

    profile_name = configure_signing(api_key: api_key)

    increment_build_number(
      build_number: next_build_number(api_key: api_key).to_s,
      xcodeproj: "anyapp.xcodeproj"
    )

    asc_key_id = ENV.fetch("ASC_KEY_ID").gsub(/\s+/, "")
    asc_issuer_id = ENV.fetch("ASC_ISSUER_ID").gsub(/\s+/, "")
    asc_key_path = ENV.fetch("ASC_KEY_PATH")

    xcode_auth_args = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath", asc_key_path,
      "-authenticationKeyID", asc_key_id,
      "-authenticationKeyIssuerID", asc_issuer_id
    ]

    if ENV["CI"]
      xcode_auth_args << "ENABLE_PREVIEWS=NO"
      xcode_auth_args << "COMPILER_INDEX_STORE_ENABLE=NO"
    end

    build_options = {
      scheme: "anyapp",
      project: "anyapp.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "anyapp.ipa",
      include_bitcode: false,
      clean: ENV["DERIVED_DATA_CACHE_HIT"] != "true",
      xcargs: xcode_auth_args.join(" ")
    }

    if profile_name
      build_options[:export_options] = {
        provisioningProfiles: {
          "com.ijaejun.anyapp" => profile_name
        },
        signingStyle: "manual"
      }
    else
      build_options[:export_options] = {
        signingStyle: "automatic",
        teamID: "T5CBR768BM"
      }
    end

    build_app(build_options)

    upload_to_testflight_safely(api_key: api_key)
  end
end
