default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  private_lane :connect_api_token do
    Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: ENV.fetch("ASC_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  # 만료·CI 잉여 Development 인증서를 정리해 Apple 계정 한도(3개)를 확보합니다.
  private_lane :prune_certificates do
    Spaceship::ConnectAPI.token = connect_api_token

    Spaceship::ConnectAPI::Certificate.all.each do |certificate|
      next unless certificate.expiration_date

      expires_at = Time.parse(certificate.expiration_date.to_s)
      next if expires_at >= Time.now

      UI.message("Revoking expired certificate: #{certificate.display_name} (#{certificate.id})")
      certificate.delete!
    end

    return unless ENV["CI"]

    development_certs = Spaceship::ConnectAPI::Certificate.all.select do |certificate|
      certificate.certificate_type == "IOS_DEVELOPMENT"
    end

    return if development_certs.length <= 1

    development_certs
      .sort_by { |certificate| Time.parse(certificate.expiration_date.to_s) }
      .first(development_certs.length - 1)
      .each do |certificate|
        UI.message("Revoking excess CI development certificate: #{certificate.display_name} (#{certificate.id})")
        certificate.delete!
      end
  end

  private_lane :setup_distribution_signing do |options|
    api_key = options[:api_key]

    prune_certificates

    begin
      cert(api_key: api_key, force: false)
    rescue StandardError => e
      UI.important("Distribution certificate setup failed, retrying with force: #{e.message}")
      cert(api_key: api_key, force: true)
    end

    sigh(
      api_key: api_key,
      app_identifier: "com.ijaejun.anyapp",
      force: false
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "anyapp.xcodeproj",
      targets: ["anyapp"],
      team_id: "T5CBR768BM",
      bundle_identifier: "com.ijaejun.anyapp",
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution"
    )

    profile_name
  end

  private_lane :configure_signing do |options|
    api_key = options[:api_key]

    if ENV["PROVISIONING_PROFILE_NAME"]
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "anyapp.xcodeproj",
        targets: ["anyapp"],
        team_id: "T5CBR768BM",
        bundle_identifier: "com.ijaejun.anyapp",
        profile_name: ENV.fetch("PROVISIONING_PROFILE_NAME"),
        code_sign_identity: "Apple Distribution"
      )
      next ENV.fetch("PROVISIONING_PROFILE_NAME")
    end

    if ENV["CI"]
      next setup_distribution_signing(api_key: api_key)
    end

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "anyapp.xcodeproj",
      targets: ["anyapp"],
      team_id: "T5CBR768BM",
      bundle_identifier: "com.ijaejun.anyapp"
    )

    nil
  end

  # 빌드 번호 = max(GITHUB_RUN_NUMBER, TestFlight 최신 빌드 + 1)
  # 자세한 정책은 docs/release.md 참고
  private_lane :next_build_number do |options|
    api_key = options[:api_key]
    run_number = ENV.fetch("GITHUB_RUN_NUMBER", "0").to_i
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.ijaejun.anyapp",
      initial_build_number: 0
    )
    [run_number, latest + 1].max
  end

  desc "Build and upload a beta build to TestFlight"
  lane :beta do
    api_key = asc_api_key
    profile_name = configure_signing(api_key: api_key)

    increment_build_number(
      build_number: next_build_number(api_key: api_key).to_s,
      xcodeproj: "anyapp.xcodeproj"
    )

    asc_key_id = ENV.fetch("ASC_KEY_ID").gsub(/\s+/, "")
    asc_issuer_id = ENV.fetch("ASC_ISSUER_ID").gsub(/\s+/, "")
    asc_key_path = ENV.fetch("ASC_KEY_PATH")

    xcode_auth_args = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath", asc_key_path,
      "-authenticationKeyID", asc_key_id,
      "-authenticationKeyIssuerID", asc_issuer_id
    ]

    if ENV["CI"]
      xcode_auth_args << "ENABLE_PREVIEWS=NO"
      xcode_auth_args << "COMPILER_INDEX_STORE_ENABLE=NO"
    end

    build_options = {
      scheme: "anyapp",
      project: "anyapp.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "anyapp.ipa",
      include_bitcode: false,
      clean: ENV["DERIVED_DATA_CACHE_HIT"] != "true",
      xcargs: xcode_auth_args.join(" ")
    }

    if profile_name
      build_options[:export_options] = {
        provisioningProfiles: {
          "com.ijaejun.anyapp" => profile_name
        },
        signingStyle: "manual"
      }
    else
      build_options[:export_options] = {
        signingStyle: "automatic",
        teamID: "T5CBR768BM"
      }
    end

    build_app(build_options)

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      uses_non_exempt_encryption: false
    )
  end
end
